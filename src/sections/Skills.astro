---
import skills from '../data/skills.json';
import TerminalWindow from '../components/TerminalWindow.astro';
import SectionHeader from '../components/SectionHeader.astro';
import SkillGroup from '../components/SkillGroup.astro';
---

<section class="px-4 py-16">
  <div class="mx-auto max-w-5xl">
    <TerminalWindow title="package.json">
      <SectionHeader path="~/portfolio/skills" command="cat package.json | jq '.dependencies'" />
      <div class="rounded border border-white/10 bg-black/40 p-4 font-mono text-sm">
        <p class="text-keyword-orange mb-3">dependencies:</p>
        <dl class="grid grid-cols-[minmax(0,auto)_1fr] gap-x-6 gap-y-2">
          {Object.entries(skills).map(([group, list]) => (
            <SkillGroup group={group} skills={list} />
          ))}
        </dl>
      </div>
    </TerminalWindow>
  </div>
</section>
