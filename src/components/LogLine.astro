---
interface Entry {
  dateRange: string;
  title: string;
  organization?: string;
  details?: string[];
  type?: string;
}

interface Props {
  entry: Entry;
}

const { entry } = Astro.props;
const level = entry.type === 'education' ? 'EDU' : 'INFO';
const levelColor = entry.type === 'education' ? 'text-electric-blue' : 'text-neon-green';
---

<div
  class="mb-4 border-l-2 border-white/10 pl-4 last:mb-0 hover:border-neon-green/50 transition-colors"
>
  <div class="flex flex-wrap items-baseline gap-2 text-sm">
    <span class="text-electric-blue font-semibold">[{entry.dateRange}]</span>
    <span class:list={['text-xs font-bold', levelColor]}>{level}</span>
    <span class="text-terminal-text font-bold">{entry.title}</span>
    {entry.organization && <span class="text-terminal-muted">@ {entry.organization}</span>}
  </div>
  {
    entry.details && entry.details.length > 0 && (
      <ul class="mt-1 list-disc list-inside text-sm text-terminal-muted leading-relaxed">
        {entry.details.map((detail) => (
          <li>{detail}</li>
        ))}
      </ul>
    )
  }
</div>
