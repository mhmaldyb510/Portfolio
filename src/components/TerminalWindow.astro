---
interface Props {
  title?: string;
  class?: string;
}

const { title = 'terminal', class: className = '' } = Astro.props;
---

<div
  class:list={[
    'rounded-lg border border-white/10 bg-panel overflow-hidden transition-all duration-300',
    'hover:border-neon-green/30 hover:shadow-[0_0_24px_rgba(57,255,20,0.08)]',
    className,
  ]}
>
  <div class="flex items-center gap-3 px-4 py-3 border-b border-white/10 bg-black">
    <div class="flex items-center gap-1.5">
      <span class="w-3 h-3 rounded-full bg-[#ff5f56] ring-1 ring-black/50"></span>
      <span class="w-3 h-3 rounded-full bg-[#ffbd2e] ring-1 ring-black/50"></span>
      <span class="w-3 h-3 rounded-full bg-[#27c93f] ring-1 ring-black/50"></span>
    </div>
    <span class="ml-2 text-xs text-terminal-muted font-mono">{title}</span>
  </div>
  <div class="p-4 sm:p-5">
    <slot />
  </div>
</div>
